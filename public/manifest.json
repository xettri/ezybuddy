{
  "manifest_version": 3,
  "name": "EzyBuddy",
  "version": "0.1.0",
  "description": "AI chat assistant that understands any webpage — summarize, ask questions, and get smart answers, all offline.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "EzyBuddy"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentMain.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": []
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://* wss://*; style-src 'self' 'unsafe-inline';",
    "sandbox": "sandbox allow-scripts; script-src 'self';"
  }
}
